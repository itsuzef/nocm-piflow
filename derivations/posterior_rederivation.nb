        RowBox[{"-", "2"}], "A"}], "]"}], " ", "term"}]}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"logZFull", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"B", "^", "2"}]}], "/", 
      RowBox[{"(", 
       RowBox[{"4", " ", "A"}], ")"}]}], "+", "Const0"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Full log-normalizer:           \>\"", ",", "logZFull"}], 
   "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Truncated \[CapitalDelta]LogW:               \>\"", ",", 
