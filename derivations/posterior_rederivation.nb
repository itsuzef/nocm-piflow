      RowBox[{"\[Zeta]", "/", "2"}], "\[CenterDot]", "x0\.b2"}], "+", 
     RowBox[{"v", "\[CenterDot]", "x0"}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ClearAll", "[", "x0", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"logQ", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x0", "-", "\[Mu]k"}], ")"}], "^", "2"}]}], "/", 
     RowBox[{"(", 
      RowBox[{"2", " ", "vk"}], ")"}]}], "-", 
    RowBox[{
     RowBox[{"\[Zeta]", "/", "2"}], "*", 
     RowBox[{"x0", "^", "2"}]}], "+", 
    RowBox[{"v", "*", "x0"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"logQ", "=", 
    RowBox[{"Expand", "[", "logQ", "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"A", "=", 
    RowBox[{"Coefficient", "[", 
     RowBox[{"logQ", ",", "x0", ",", "2"}], "]"}]}], ";"}], "    ", 
  RowBox[{"(*", " ", 
   RowBox[{"=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", 
      RowBox[{"(", 
