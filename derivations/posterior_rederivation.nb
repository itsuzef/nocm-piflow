Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Zeta]", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[Alpha]t", "/", "\[Sigma]t"}], ")"}], "^", "2"}], "-", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[Alpha]s", "/", "\[Sigma]s"}], ")"}], "^", "2"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Nu]", "=", 
   RowBox[{
    RowBox[{"\[Alpha]t", "*", 
     RowBox[{"xt", "/", 
      RowBox[{"\[Sigma]t", "^", "2"}]}]}], "-", 
    RowBox[{"\[Alpha]s", "*", 
     RowBox[{"xs", "/", 
      RowBox[{"\[Sigma]s", "^", "2"}]}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"dk", "=", 
    RowBox[{
     RowBox[{"vk", "*", "\[Zeta]"}], "+", "1"}]}], ";"}], " ", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Mu]Post", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"vk", "*", "\[Nu]"}], "+", "\[Mu]k"}], ")"}], "/", "dk"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalDelta]LogW", "=", 
    RowBox[{"\[Mu]k", "*", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Nu]", "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "2"}], ")"}], "*", "\[Zeta]", "*", "\[Mu]k"}]}], 
       ")"}], "/", "dk"}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"===", 
    RowBox[{
     RowBox[{"Full", " ", "Completing"}], "-", "the", "-", 
     RowBox[{"Square", " ", "Log"}], "-", "Normalizer"}], "==="}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Multiply", " ", "N", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x0", ";", "\[Mu]k"}], ",", "vk"}], ")"}], " ", "by", " ", 
