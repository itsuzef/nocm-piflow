      RowBox[{"2", "vk"}], ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Log", " ", "Z"}], "\[LongDash]", 
