  RowBox[{"(*", " ", 
   RowBox[{"=", 
    RowBox[{
     RowBox[{"\[Mu]k", "/", "vk"}], "+", "v"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Const0", "=", 
