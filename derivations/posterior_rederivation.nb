   RowBox[{"Confirm", " ", "it", " ", "equals", " ", 
    RowBox[{"vk", "\[CenterDot]", 
     RowBox[{"v\.b2", "/", 
      RowBox[{"(", 
       RowBox[{"2", "\[CenterDot]", "dk"}], ")"}]}]}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
